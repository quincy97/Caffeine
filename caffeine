#!/bin/zsh

# Caffeine — keep your Mac awake from the terminal
# Replicates https://www.caffeine-app.net functionality

PIDFILE="/tmp/caffeine.pid"
ENDFILE="/tmp/caffeine.end"
DURFILE="/tmp/caffeine.dur"

usage() {
    cat <<'EOF'
Usage: caffeine [command] [duration]

Commands:
    (none)          Interactive menu
    on [duration]   Activate (keep Mac awake)
    off             Deactivate (allow sleep)
    status          Show current state
    toggle          Toggle on/off
    help            Show this message

Durations:
    (none)          Indefinite
    5m, 10m, 15m, 30m, 1h, 2h, 5h

Examples:
    caffeine              # Interactive menu
    caffeine on           # Stay awake indefinitely
    caffeine on 30m       # Stay awake for 30 minutes
    caffeine off          # Allow sleep again
EOF
}

parse_duration() {
    case "$1" in
        5m)   echo 300 ;;
        10m)  echo 600 ;;
        15m)  echo 900 ;;
        30m)  echo 1800 ;;
        1h)   echo 3600 ;;
        2h)   echo 7200 ;;
        5h)   echo 18000 ;;
        *)    echo 0 ;;
    esac
}

format_duration() {
    local secs=$1
    if (( secs <= 0 )); then
        echo "indefinite"
    elif (( secs >= 3600 )); then
        echo "$(( secs / 3600 ))h"
    else
        echo "$(( secs / 60 ))m"
    fi
}

is_active() {
    [[ -f "$PIDFILE" ]] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null
}

activate() {
    if is_active; then
        return 0
    fi

    local duration=0
    [[ -n "$1" ]] && duration=$(parse_duration "$1")

    local flags="-dims"
    echo "$1" > "$DURFILE"

    if (( duration > 0 )); then
        caffeinate $flags -t "$duration" &
        local end_time=$(( $(date +%s) + duration ))
        echo "$end_time" > "$ENDFILE"
    else
        caffeinate $flags &
        rm -f "$ENDFILE"
    fi

    echo $! > "$PIDFILE"
}

deactivate() {
    if ! is_active; then
        echo "  😴 Already inactive"
        return 0
    fi

    kill "$(cat "$PIDFILE")" 2>/dev/null
    rm -f "$PIDFILE" "$ENDFILE"
    echo "  😴 Caffeine OFF — sleep allowed"
}

show_status() {
    if is_active; then
        local pid=$(cat "$PIDFILE")
        local msg="  ☕ Active (PID $pid)"
        if [[ -f "$ENDFILE" ]]; then
            local end=$(cat "$ENDFILE")
            local now=$(date +%s)
            local remaining=$(( end - now ))
            if (( remaining > 0 )); then
                local min=$(( remaining / 60 ))
                local sec=$(( remaining % 60 ))
                msg="$msg — ${min}m ${sec}s remaining"
            else
                deactivate
                return
            fi
        else
            msg="$msg — indefinite"
        fi
        echo "$msg"
    else
        rm -f "$PIDFILE" "$ENDFILE"
        echo "  😴 Inactive — sleep allowed"
    fi
}

toggle() {
    if is_active; then
        deactivate
    else
        activate "$1"
    fi
}

# ─── Quiet helpers (no output, for interactive mode) ────────────────

activate_quiet() {
    local duration=0
    [[ -n "$1" ]] && duration=$(parse_duration "$1")
    local flags="-dims"
    echo "$1" > "$DURFILE"
    if (( duration > 0 )); then
        caffeinate $flags -t "$duration" &
        echo "$(( $(date +%s) + duration ))" > "$ENDFILE"
    else
        caffeinate $flags &
        rm -f "$ENDFILE"
    fi
    echo $! > "$PIDFILE"
}

deactivate_quiet() {
    kill "$(cat "$PIDFILE")" 2>/dev/null
    rm -f "$PIDFILE" "$ENDFILE"
}

cleanup_all() {
    deactivate_quiet 2>/dev/null
    rm -f "$DURFILE"
}

# ─── Live Status Screen ───────────────────────────────────────────

header() {
    echo ""
    echo "  ┌─────────────────────────────────────┐"
    echo "  │           ☕  C A F F E I N E        │"
    echo "  │       Keep your Mac awake            │"
    echo "  └─────────────────────────────────────┘"
    echo ""
}

render_status() {
    local expired=$1
    clear
    header

    if [[ "$expired" == "expired" ]]; then
        echo "  ⏰ Timer has ended!"
        echo ""
        echo "  ─────────────────────────────────────"
        echo ""
        echo "  Your Mac can now sleep normally."
        echo ""
        printf "  \033[90mr Restart    m New duration    q Quit\033[0m\n"
        return
    fi

    if is_active; then
        if [[ -f "$ENDFILE" ]]; then
            local end=$(cat "$ENDFILE")
            local now=$(date +%s)
            local remaining=$(( end - now ))
            if (( remaining > 0 )); then
                local hrs=$(( remaining / 3600 ))
                local min=$(( (remaining % 3600) / 60 ))
                local sec=$(( remaining % 60 ))
                if (( hrs > 0 )); then
                    printf "  ☕ ON — %dh %dm %ds remaining\n" $hrs $min $sec
                else
                    printf "  ☕ ON — %dm %ds remaining\n" $min $sec
                fi
            fi
        else
            echo "  ☕ ON — indefinite"
        fi
        echo ""
        echo "  ─────────────────────────────────────"
        echo ""
        printf "  \033[33m⚠  Keep this terminal open.\033[0m\n"
        echo "  Closing the terminal will stop Caffeine."
        echo ""
        printf "  \033[90mo Turn off    m Change duration    q Quit\033[0m\n"
    else
        echo "  😴 OFF"
        echo ""
        echo "  ─────────────────────────────────────"
        echo ""
        echo "  Your Mac will sleep normally."
        echo ""
        printf "  \033[90mm Turn on    q Quit\033[0m\n"
    fi
}

confirm_quit() {
    clear
    header
    if is_active; then
        printf "  \033[1;33m⚠  Caffeine is still running!\033[0m\n"
        echo ""
        echo "  Quitting will turn off Caffeine and"
        echo "  your Mac will be allowed to sleep."
        echo ""
        echo "  ─────────────────────────────────────"
        echo ""
        printf "  \033[1;31m  Are you sure you want to quit?\033[0m\n"
    else
        echo "  Are you sure you want to quit?"
    fi
    echo ""
    printf "  \033[90my Yes, quit    n No, go back\033[0m\n"

    while true; do
        local key=""
        read -rsk1 key
        case "$key" in
            y|Y) return 0 ;;
            n|N|$'\x1b') return 1 ;;
            $'\n'|$'\r'|"") return 1 ;;
        esac
    done
}

live_status() {
    local timer_expired=false
    printf "\033[?25l"
    trap 'printf "\033[?25h"' EXIT INT TERM

    while true; do
        # Detect timer expiry
        if [[ "$timer_expired" == false ]] && [[ -f "$ENDFILE" ]]; then
            local end=$(cat "$ENDFILE")
            local now=$(date +%s)
            if (( now >= end )) || ! is_active; then
                deactivate_quiet 2>/dev/null
                timer_expired=true
            fi
        fi

        if [[ "$timer_expired" == true ]]; then
            render_status "expired"
            local key=""
            read -rsk1 key
            case "$key" in
                r|R)
                    local last_dur=""
                    [[ -f "$DURFILE" ]] && last_dur=$(cat "$DURFILE")
                    activate_quiet "$last_dur"
                    timer_expired=false
                    ;;
                m|M)
                    printf "\033[?25h"
                    interactive_menu
                    return
                    ;;
                q|Q)
                    if confirm_quit; then
                        cleanup_all
                        printf "\033[?25h"
                        clear
                        echo ""
                        echo "  😴 Caffeine is off. Goodbye!"
                        echo ""
                        return
                    fi
                    ;;
                $'\x1b')
                    read -rsk2 key 2>/dev/null
                    ;;
            esac
            continue
        fi

        render_status

        local key=""
        read -rsk1 -t 1 key 2>/dev/null

        if [[ "$key" == $'\x1b' ]]; then
            read -rsk2 key 2>/dev/null
            continue
        fi

        case "$key" in
            o|O)
                if is_active; then
                    deactivate_quiet
                fi
                ;;
            m|M)
                printf "\033[?25h"
                interactive_menu
                return
                ;;
            q|Q)
                if confirm_quit; then
                    cleanup_all
                    printf "\033[?25h"
                    clear
                    echo ""
                    echo "  😴 Caffeine is off. Goodbye!"
                    echo ""
                    return
                fi
                ;;
        esac
    done
}

# ─── Interactive Menu ───────────────────────────────────────────────

read_key() {
    local key
    read -rsk1 key
    if [[ "$key" == $'\x1b' ]]; then
        read -rsk2 key
        case "$key" in
            '[A') echo "up" ;;
            '[B') echo "down" ;;
            *)    echo "" ;;
        esac
    elif [[ "$key" == $'\n' || "$key" == $'\r' || "$key" == "" ]]; then
        echo "enter"
    elif [[ "$key" == "q" || "$key" == "Q" ]]; then
        echo "quit"
    else
        echo ""
    fi
}

render() {
    local selected=$1
    shift
    local options=("$@")
    local count=${#options[@]}

    clear

    echo ""
    echo "  ┌─────────────────────────────────────┐"
    echo "  │           ☕  C A F F E I N E        │"
    echo "  │       Keep your Mac awake            │"
    echo "  └─────────────────────────────────────┘"
    echo ""

    if is_active; then
        local pid=$(cat "$PIDFILE")
        if [[ -f "$ENDFILE" ]]; then
            local end=$(cat "$ENDFILE")
            local now=$(date +%s)
            local remaining=$(( end - now ))
            if (( remaining > 0 )); then
                local min=$(( remaining / 60 ))
                local sec=$(( remaining % 60 ))
                echo "  Status:  ☕ ON — ${min}m ${sec}s remaining"
            else
                echo "  Status:  😴 OFF"
            fi
        else
            echo "  Status:  ☕ ON — indefinite"
        fi
    else
        echo "  Status:  😴 OFF"
    fi

    echo ""
    echo "  ─────────────────────────────────────"
    echo ""

    for (( i=1; i<=count; i++ )); do
        if (( i == selected )); then
            printf "    \033[1;36m❯ %s\033[0m\n" "${options[$i]}"
        else
            printf "      %s\n" "${options[$i]}"
        fi
    done

    echo ""
    printf "  \033[90m↑↓ Navigate  ⏎ Select  q Quit\033[0m\n"
}

interactive_menu() {
    local selected=1

    if is_active; then
        local options=(
            "Turn OFF"
            "───────────────────────────"
            "Change duration → Indefinite"
            "Change duration → 5 minutes"
            "Change duration → 10 minutes"
            "Change duration → 15 minutes"
            "Change duration → 30 minutes"
            "Change duration → 1 hour"
            "Change duration → 2 hours"
            "Change duration → 5 hours"
        )
        local actions=(off sep indefinite 5m 10m 15m 30m 1h 2h 5h)
    else
        local options=(
            "Turn ON  → Indefinite"
            "Turn ON  → 5 minutes"
            "Turn ON  → 10 minutes"
            "Turn ON  → 15 minutes"
            "Turn ON  → 30 minutes"
            "Turn ON  → 1 hour"
            "Turn ON  → 2 hours"
            "Turn ON  → 5 hours"
        )
        local actions=(indefinite 5m 10m 15m 30m 1h 2h 5h)
    fi

    local count=${#options[@]}

    printf "\033[?25l"
    trap 'printf "\033[?25h"' EXIT INT TERM

    render $selected "${options[@]}"

    while true; do
        local key=$(read_key)

        case "$key" in
            up)
                (( selected > 1 )) && (( selected-- ))
                [[ "${actions[$selected]}" == "sep" ]] && (( selected > 1 )) && (( selected-- ))
                render $selected "${options[@]}"
                ;;
            down)
                (( selected < count )) && (( selected++ ))
                [[ "${actions[$selected]}" == "sep" ]] && (( selected < count )) && (( selected++ ))
                render $selected "${options[@]}"
                ;;
            enter)
                printf "\033[?25h"
                local action="${actions[$selected]}"
                case "$action" in
                    sep) ;;
                    off)
                        deactivate_quiet
                        live_status
                        return 0
                        ;;
                    indefinite)
                        is_active && { kill "$(cat "$PIDFILE")" 2>/dev/null; rm -f "$PIDFILE" "$ENDFILE"; }
                        activate_quiet ""
                        live_status
                        return 0
                        ;;
                    *)
                        is_active && { kill "$(cat "$PIDFILE")" 2>/dev/null; rm -f "$PIDFILE" "$ENDFILE"; }
                        activate_quiet "$action"
                        live_status
                        return 0
                        ;;
                esac
                ;;
            quit)
                printf "\033[?25h"
                live_status
                return 0
                ;;
        esac
    done
}

# ─── Main ───────────────────────────────────────────────────────────

case "${1:-}" in
    on)       activate "$2"; live_status ;;
    off)      deactivate_quiet; live_status ;;
    status)   show_status ;;
    toggle)   toggle "$2"; live_status ;;
    help|-h|--help) usage ;;
    "")       interactive_menu ;;
    *)        usage; exit 1 ;;
esac
